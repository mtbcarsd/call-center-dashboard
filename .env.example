# PostgreSQL (локально: значения ниже; в docker-compose используются как есть)
POSTGRES_USER=call_center_app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=call_center
# Полная строка подключения — для локального запуска вне docker-compose
DATABASE_URL=postgresql://call_center_app:change-me@localhost:5432/call_center

# HuggingFace-токен для pyannote (диаризация). Получить: https://hf.co/settings/tokens
# Перед использованием нужно принять условия доступа на:
#   https://hf.co/pyannote/speaker-diarization-3.1
#   https://hf.co/pyannote/segmentation-3.0
#   https://hf.co/pyannote/speaker-diarization-community-1
HF_TOKEN=

# LLM — любой OpenAI-совместимый эндпоинт. По умолчанию локальный Ollama;
# для Groq/OpenRouter/Together меняются только эти две переменные, код не трогаем.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5-coder:7b
LLM_API_KEY=ollama

WHISPER_MODEL=medium
WHISPER_LANGUAGE=ru

# OpenWebUI Pipelines — ключ для связи openwebui <-> pipelines (в docker-compose)
PIPELINES_API_KEY=0p3n-w3bu!
WEBUI_SECRET_KEY=change-me

# API-ключ OpenWebUI (обратное направление: pipelines скачивает загруженные в чат
# аудиофайлы через GET /api/v1/files/{id}/content). Создать: залогиниться в
# http://localhost:3000 → своя иконка профиля → Settings → Account → API Keys → Create.
OPENWEBUI_API_KEY=

# Grafana (бонус)
GRAFANA_ADMIN_PASSWORD=admin

# S3-совместимое хранилище для аудиофайлов (Railway Bucket или любое другое) —
# используется дашбордом для аудиоплеера и pipeline.py для заливки записей.
AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_DEFAULT_REGION=auto

# Публичный (proxy) connection string сервиса Postgres на Railway — нужен только
# scripts/add_new_calls.py и scripts/fix_new_calls_analysis.py, чтобы синхронизировать
# новые звонки в обе базы (локальную и Railway) с локальной машины. Получить:
# `railway variables --service Postgres --kv` → DATABASE_PUBLIC_URL.
RAILWAY_DATABASE_PUBLIC_URL=
